<#compress>
<div>
   <form id="loginForm" class="form-signin" method="post" action="${(contextPath)!''}/cf/login"  autocomplete="off">
     
      <#if queryString?? && queryString?has_content>
		 <#if resetPasswordSuccess??>    
      		<div class="alert alert-success" role="alert">${innerTemplateObj.resetPasswordSuccess} </div>
      	 </#if> 
	  </#if>            
      <p class="divdeform">   
         <label for="username" class="formlablename"><@resourceBundleWithDefault "jws.email" "Email"/></label>   
         <span class="formicosn"><i class="fa-solid fa-user" aria-hidden="true"></i></span>    
         <#if innerTemplateObj.previousMail?? && innerTemplateObj.previousMail?has_content && innerTemplateObj.prevAuthType?has_content && innerTemplateObj.prevAuthType == "2">
         	<input type="email" id="email" value="${innerTemplateObj.previousMail?html}" name="email" class="form-control" placeholder="<@resourceBundleWithDefault "jws.enteremail" "Enter Email" />" required autofocus> 
		<#else>
			<input type="email" id="email"  name="email" class="form-control" placeholder="<@resourceBundleWithDefault "jws.enteremail" "Enter Email" />" required autofocus> 
		</#if>
      </p>
      <#if innerTemplateObj.verificationType?? && innerTemplateObj.verificationType=="2">   
      <p class="divdeform">   
         <label for="password" class="formlablename">Password</label>    
         <span class="formicosn"><i class="fa-solid fa-key" aria-hidden="true"></i></span>  
         <input type="password" id="textPassword" name="textPassword" class="form-control" placeholder="<@resourceBundleWithDefault "jws.entertotp" "Enter TOTP"/>" required>   
         <span class="passview" onclick="showHidePassword(this);"><i class="fa fa-eye" aria-hidden="true"></i></span>    
      </p>
      <#if innerTemplateObj.requestId?? && innerTemplateObj.requestId?has_content> 
			<input type="hidden" id="requestId" name="requestId" value="${innerTemplateObj.requestId}"/>  
	    </#if>
      <#if innerTemplateObj.enableCaptcha == "true">     
      <div class="captchablock"> 
         <img id="imgCaptcha" name="imgCaptcha" src="">   
         <span id="reloadCaptcha"><i class="fa fa-refresh" aria-hidden="true"></i></span>    
         <label for="captcha" class="sr-only"><@resourceBundleWithDefault "jws.entercaptcha" "Enter Captcha"/></label>  
         <input type="text" id="captcha" name="captcha" class="form-control" placeholder="<@resourceBundleWithDefault "jws.entercaptcha" "Enter Captcha"/>" required autofocus >    
      </div>
      </#if>  
      <div class="blockpass">
      <span class="forgotpassword">   
      	<a href="${(contextPath)!''}/cf/configureTOTP"><@resourceBundleWithDefault "jws.notconfclickhere" "Not Configured? Click Here"/></a>    
      </span>                           
      </#if> 
      </div>
      <input type="hidden" id="enableAuthenticationType" name="enableAuthenticationType" value="2"/> 
      <input type="hidden" id="password" name="password"/>                           
      <div class="loginbtn"><button class="btn btn-lg btn-primary btn-block" type="submit" onclick= "encryptPasswordOnSubmit();"><@resourceBundleWithDefault "jws.signin" "Sign In"/></button></div> 
      <#if innerTemplateObj.enableRegistration?? && innerTemplateObj.enableRegistration?string == "true" >  
      <p class="registerlink"><@resourceBundleWithDefault "jws.newuser" "New User"/>?   
         <a href="${(contextPath)!''}/cf/register"> <@resourceBundleWithDefault "jws.registerhere" "Register"/></a>   
      </p>
      </#if>  
   </form>
</div>
<script>
 localStorage.setItem('r', null);
 contextPath = "${(contextPath)!''}";
   function showHidePassword(thisObj){
   	var element = $(thisObj).parent().find("input[name='textPassword']");
   	if (element.prop("type") === "password") {
   		element.prop("type","text");
   		$(thisObj).find("i").removeClass("fa-eye");
   		 $(thisObj).find("i").addClass("fa-eye-slash");
   		 $("#textPassword").focus();
   	} else {
   		 element.prop("type","password");
   		 $(thisObj).find("i").removeClass("fa-eye-slash");
   		 $(thisObj).find("i").addClass("fa-eye");
   		 $("#textPassword").focus();
   	}
   
   }		
   $(function(){
    <#if innerTemplateObj.enableCaptcha == "true"> 
   	 var imagesrc=contextPath+"/cf/captcha/lc";
     generateCaptch(imagesrc);   	
   	</#if>
   });
   
   $("#reloadCaptcha").click(function(event){
   		 var imagesrc=contextPath+"/cf/captcha/lc"+"#";
         generateCaptch(imagesrc);
          
    });
    function encryptPasswordOnSubmit(){
        var password = $("#textPassword").val();
         <#if innerTemplateObj.salt?? && innerTemplateObj.salt?has_content> 
            var encryptionKey = "${innerTemplateObj.salt}";
        </#if>
        var encryptedPassword = encryptPassword(password, encryptionKey);
        $("#password").val(encryptedPassword);
    }

    function padOrTruncateKey(key, length) {
        if (key.length < length) {
            return key.padEnd(length, '0');
        } else if (key.length > length) {
            return key.substring(0, length);
        }
        return key;
    }

    function encryptPassword(password, encryptKey) {
        const paddedKey = padOrTruncateKey(encryptKey, 16); 
        const key = CryptoJS.enc.Utf8.parse(paddedKey);
        const encrypted = CryptoJS.AES.encrypt(password, key, {
            mode: CryptoJS.mode.ECB,
            padding: CryptoJS.pad.Pkcs7
        });
        return encrypted.toString();
    }
    
 /*function generateCaptch(imagesrc) {
       // alert("generate Captch");
     const imgElement = document.getElementById('imgCaptcha');    
     fetch(imagesrc, {
        headers: {

        'r':  localStorage.getItem('r')
        }
      }) // Fetch the image using its 'src' attribute
     .then(response => {
      // Access the desired header
       localStorage.setItem('r', response.headers.get('r'));
