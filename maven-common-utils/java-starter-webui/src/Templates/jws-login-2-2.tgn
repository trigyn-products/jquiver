	      return response.blob();
	     // console.log('Image URL is valid');
	    } else {
	     // console.log('Image URL is invalid');
	      return null;
	    }	
       
	     })
	    .then((blob) => {
	       if(blob!=null){
	             //set image to image Src
	              const objectURL = URL.createObjectURL(blob);
	              imgElement.src = objectURL;
                      
                         if ($('#captcha').prop('disabled')) {
                           $("#captcha").removeAttr('disabled');
			}
		   }
		else{
		     //set path and show error Message and disable text
		      imgElement.src = "${(contextPath)!''}/webjars/1.0/images/noimg.png";
		      $("#captcha").attr('disabled','disabled');
              $("#captchaGenerationError").attr("style","display:block");
               $("#captchaGenerationError").html("<@resourceBundle "jws.captchGenerationFailed"/>");
		    }
	     })
      .catch(error => {
       $("#captchaGenerationError").attr("style","display:block");
       $("#captchaGenerationError").html("<@resourceBundle "jws.fetchCaptchError"/>");

     });
}*/

document.getElementById('loginForm').addEventListener('submit', (event) => {
    event.preventDefault(); // Prevent full form submit

    const formData = new FormData(event.target);

    fetch(event.target.action, {
        method: 'POST',
        headers: {
            'r': localStorage.getItem('r')
        },
        body: formData
    })
    .then(response => {
        // Get HTML text + the final response URL
        return response.text().then(html => ({ html, url: response.url }));
    })
    .then(({ html, url }) => {
       // Convert HTML string into DOM
        let tempDiv = document.createElement("div");
        tempDiv.innerHTML = html;
        // Get exception message from response HTML
        let exceptionMessage = tempDiv.querySelector("#exceptionMessage")?.innerText;

        if (exceptionMessage) {
            $("#LoginFormError").show().html(exceptionMessage);
            var imagesrc = contextPath + "/cf/captcha/lc" + "#";
            generateCaptch(imagesrc);
            return;
        }
        document.open();
        document.write(html);
        document.close();
        
        if (url !== null && url !== undefined && url !== '') {
            window.history.pushState({}, '', url);
        }
    })
    .catch(error => {
        console.error("Login error", error);
        $("#LoginFormError").attr("style", "display:block");
        $("#LoginFormError").html(exceptionMessage);
    });
});
</script>
</#compress>