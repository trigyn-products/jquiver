	    Autocomplete Id: {              // Autocomplete Id should be replaced with the actual Autocomplete id
	    prefetch: true,
	    multiple: false,
	    render: function(item) {
	        if (!item) return '';
	        return '<div style="padding:4px;">' +
	                   '<strong>' + (item.targetTypeName || '') + '</strong><br/>' +   
	                   '<small>' + (item.targetTypeId || '') + '</small>' +
	               '</div>';
	               //targetTypeId, targetTypeName should be replaced with actual column which needs to be shown in text box
	    },
	    extractText: function(item) {
	        if (!item) return '';
	        let parts = [];
	        if (item.targetTypeName) parts.push(item.targetTypeName);          //targetTypeName should be replaced with actual column which needs to be shown in text box
	        if (item.targetTypeId) parts.push('[' + item.targetTypeId + ']');  //targetTypeId should be replaced with actual column which needs to be shown in text box
	        return parts.join(' '); 
	    },
	
	    select: function(item, component) {
	    if (!item || !component) return;
	
	    const cfg = component.getRuntimeConfig();
	
	    const text = cfg.extractText ? cfg.extractText(item) : '';
	
	    if (component.input) component.input.value = text;
	    if (component.hiddenInput) component.hiddenInput.value = item.targetTypeId || ''; //targetTypeId should be replaced with actual id(primary key) column
	
	    component.selectedLabel = text;
	    component.selectedValue = item.targetTypeId || '';  //targetTypeId should be replaced with actual id(primary key) column
	    component.dataValue = item.targetTypeId || '';      //targetTypeId should be replaced with actual id(primary key) column
	},
	    resetAutocomplete: function(component) {
	        if (!component) return;
	        if (component.input) component.input.value = '';
	        if (component.hiddenInput) component.hiddenInput.value = '';
	        component.selectedLabel = null;
	        component.selectedValue = null;
	        component.dataValue = null;
	    }
	}
	//if there are mulitple autocompletes then need to add above configuration accordingly for all Autocompletes after adding comma(,)
	};
