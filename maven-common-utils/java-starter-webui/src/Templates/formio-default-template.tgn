    //For file bin
    function fileConfigRenderer(fileObj) {
    let fileUploadId = fileObj["id"];
    let fileName = fileObj["name"];
    let btnTxt = resourceBundleData("jws.copyFilePath,jws.fileName");

    // Create a single root <div> with all actions inside
    let actionElem = 
        "<div class='fileicons'>" +
            "<span class='iconcovercls' title='" + btnTxt["jws.copyFilePath"] + "'>" +
                "<i class='fileupload-actions fa fa-copy float-right' onclick=\"copyFilePath('" + fileUploadId + "')\"></i>" +
            "</span>" +
            "<span class='iconcovercls' title='" + btnTxt["jws.fileName"] + "'>" +
                "<i class='fileupload-actions fa fa-info float-right' onclick=\"fileName('" + fileName + "')\"></i>" +
            "</span>" +
            "<span class='iconcovercls' title='Delete'>" +
                "<i class='fileupload-actions fa fa-trash float-right' data-fileid='" + fileUploadId + "'></i>" +
            "</span>" +
        "</div>";

    return actionElem;
    }

    function fileName(a_fileName){
        showMessage("File Name: " + a_fileName, "success");
    }

    function copyFilePath(a_fileUploadId){
        let input = $("<input>");
        $("body").append(input);
        input.val(window.location.origin + contextPath+"/cf/files/" + a_fileUploadId).select();
        document.execCommand("copy");
        input.remove();
        showMessage("File path copied successfully", "success");
    }

    //Done file config Render
    //File Bin Config End
         
		Formio.createForm(document.getElementById('formioBody'), formMetaData, formOptions).then(function(form) {              
            form.submission = {              
                data: <#noparse>${(resultSetObject.formData)!""}</#noparse>
            };
            form.on('submit', function(submission) {
            <!-- TODO : Change the primaryKeyColumnName as per the table -->  
            	<#noparse> submission.data.id = $("#primaryKeyId").val();               
                if(submission["data"].${(primaryKeyColumnName)!''} != undefined){
                    $("#primaryKeyId").val(submission["data"].${(primaryKeyColumnName)!''});
                }  </#noparse>
                onSaveButtonClick(isEdit);  
              
            });
            
            form.on('cancelFormIoEvent', (event) => {
    			// Your custom logic for canceling the form
    			// You can redirect or clear the form fields
    			// form.reset();  // Reset the form fields
    			// window.location.href = '/home';  // Optionally redirect to another page
			});
        });
        
        <#noparse>
         $(document).ready(function() {
            $('.form-check-input').change(function() {
                var inputType = $(this).attr('type');
            	if(inputType=="checkbox"){
            		var id = this.name;
	                id = id.replace(/[^a-z0-9\s]/gi, '').replace(/[_\s]/g, '-');
		            $('#hidden-'+id).remove();
	                var val = 0;
	                if(this.checked) {
	                    this.value = 1;                   
	                } else {                    
	                    this.value = val;
	                    $(this).after('<input id = "hidden-' + id + '" name = "' + this.name + '" type="hidden" value = "' + val + '" />');
	                    
	                }
            	}                        
            });
        });
        function onValidation(a_serializedFormData){
   		const rawFormData = a_serializedFormData.get('formData');
        let parsedFormData;
        try {
            parsedFormData = JSON.parse(rawFormData); 
        } catch (exec) {
            showMessage("Invalid JSON in formData", "error");
            return false;
        }	       
        let fieldList = ${(fieldList)!''}        
        for (let field of parsedFormData) {
	        let fieldName = field.name;
	        let fieldValue = field.value ?? '';     
	        let match = fieldName.match(/^data\[(.+)\]$/);
            let baseName = match ? match[1] : fieldName; 
            let fieldConfig = fieldList.find(f => f.fieldName === baseName);                     
            if (fieldConfig) {                       
                let pattern =  fieldConfig.regexPattern;
                let regex = new RegExp(pattern);
                if (regex.test(fieldValue) == false) {
                   var errorMessage = "Invalid value";
                   let labelText = $("input[name='data["+baseName+"]']")
	                .closest("[ref='component']")
	                .find("label[ref='label']")
	                .text()
	                .trim();
					if(labelText != ''){
						errorMessage = errorMessage +" for "+labelText;
					}
	                showMessage(errorMessage, "warn");
                    $('[name="data[' + baseName + ']"]').focus();
                    $('[name="data[' + baseName + ']"]').effect("highlight", {}, 3000);
                    return null;
                }                    
            }
	    }	    
		return a_serializedFormData;
	}
	function generateCaptch(imagesrc) {
		const imgElement = document.getElementById('imgCaptcha');    
	    fetch(imagesrc, {
	        headers: {
	
	        'r':  localStorage.getItem('r')
	        }
	      }) // Fetch the image using its 'src' attribute
		.then(response => {      	
       		localStorage.setItem('r', response.headers.get('r'));
	    	if (response.ok) {
	      		return response.blob();
	    	} else {
	      		return null;
	    	}	
       
	     })
	    .then((blob) => {
	       if(blob!=null){
				const objectURL = URL.createObjectURL(blob);
				imgElement.src = objectURL;
                $('#imgCaptcha').attr('src', objectURL);   
					if ($('#captcha').prop('disabled')) {
						$("#formCaptcha").removeAttr('disabled');
					}
		   		}
				else{
				     //set path and show error Message and disable text
				      imgElement.src = "${(contextPath)!''}/webjars/1.0/images/noimg.png";
				      $("#formCaptcha").attr('disabled','disabled');
				      //$("#captchaGenerationError").html("<@resourceBundle "jws.captchGenerationFailed"/>");
				      showMessage("<@resourceBundle "jws.captchGenerationFailed"/>", "warn");
				     // alert(resourceBundleData("jws.clearTxt"));
				    }
				 })
		      .catch(error => {
		          showMessage("<@resourceBundle "jws.fetchCaptchError"/>", "warn");
		
		});
    }
    	
    function onError(message, exception){   
		showMessage(message, "error");
	}
	
    function onSuccess(a_serverResponse){
       <!-- TODO : Change the redirect URI as per the Listing page defined through Master Generator --> 
       window.location.href = contextPath+viewPath+"/"+"${(moduleURL)!''}";
	}
    	
	function reloadCptcha(){
    	var imagesrc=contextPath+"/cf/captcha/"+formId+"_captcha";
        generateCaptch(imagesrc);
        $("#formCaptcha").val('');
	}
	
	$(document).on("click", "#reloadCaptcha", function(event) {
        reloadCptcha();
    });
       </#noparse>
       
	</script>
</html>
