        $("#toggleBoolean").val(isChecked);  
    }  */
  function toggleBooleanVal(index) {
        const checkbox = document.getElementById('toggleBooleanChkBox_'+index);
        const hiddenField = document.getElementById('toggleBoolean_'+index);
        if (checkbox && hiddenField) {
            const isChecked = checkbox.checked ? 1 : 0;
            hiddenField.value = isChecked;
        }
    }
  
  $("#reloadCaptcha").click(function(event){
     var imagesrc=contextPath+"/cf/captcha/"+formId+"_captcha"+"#";
     generateCaptch(imagesrc);
    $("#formCaptcha").val("");
});
