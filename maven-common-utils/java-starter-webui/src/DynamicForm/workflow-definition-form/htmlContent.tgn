            checkbox.addEventListener("change", function (event) {
                const idParts = checkbox.id.split("_")[1]; 
                const index = idParts[idParts.length - 1]; 
                toggleBooleanVal(index);
            });
        });
    }

	
	actionDropdownBtn.addEventListener("click", function (event) {
	    actionOptions();
	});
	
	backBtn.addEventListener("click", function (event) {
	    backToPreviousPage();
	});
	
