function isValidXML(text) {
    try {
        let parser = new DOMParser();
        let xmlDoc = parser.parseFromString(text, "application/xml");
        return !xmlDoc.querySelector("parsererror");
    } catch (e) {
        return false;
    }
}

function saveValidation(isEdit) {
    var definitionName = $("#definitionName").val().trim();

    if (definitionName === "") {
        $("#definitionName").closest("div").parent().effect("highlight", {}, 3000);
        $("#definitionName").focus();
        showMessage("Please enter the Definition Name", "warn");
        return false;
    }

    // Check allowed characters
    const re = /^[A-Za-z][\w\-\:\.]*([ ]?[\w\-\:\.]*)*$/;
    if (!re.test(definitionName)) {
        showMessage("Allowed characters are a-z, A-Z, 0-9, _, -, .,:, ", "error");
        return false;
    }

    // === File / Editor content validation ===
    let editorContent = (window.editor && window.editor.getValue().trim()) || "";
    let fileInput = document.getElementById("workflowFile");

    if (editorContent === "" && (!fileInput || fileInput.files.length === 0)) {
        showMessage("Please either upload a BPMN file OR enter BPMN content in the editor", "warn");
        return false;
    }

    // Prefer editor content
    if (editorContent !== "") {
        // ✅ Validate XML
        if (!isValidXML(editorContent)) {
            showMessage("The workflow content must be valid BPMN XML.", "error");
            window.editor.focus();
            return false;
        }

        document.getElementById("workflowFileContent").value = editorContent;
        if (!document.getElementById("workflowFileName").value) {
            document.getElementById("workflowFileName").value = "editor-input.bpmn";
        }
    } else if (fileInput.files.length > 0) {
        // If editor is empty but file uploaded
        let file = fileInput.files[0];
        document.getElementById("workflowFileName").value = file.name;
    }

    // === Duplicate check only on create ===
    if (isEdit === 0) {
        let isKeyExist = false;
        $.ajax({
            async: false,
            type: "GET",
            dataType: "json",
            url: contextPath + "/cf/cwfdn?dn=" + encodeURIComponent(definitionName),
            success: function (data) {
                isKeyExist = data === true;
            }
        });

        if (isKeyExist) {
            showMessage("This definition Name already exists. Kindly enter a different definition Name.", "error");
            $("#definitionName").focus();
            return false;
        }
    }

    return true;
}



function initiatePage() {
    const context = this;

    // Configure Monaco loader
    require.config({ paths: { "vs": "../webjars/1.0/monaco/min/vs" }, waitSeconds: 120 });

    require(["vs/editor/editor.main"], function () {

        // === Get initial content from hidden field or default empty ===
        let hiddenContent = document.getElementById("workflowFileContent").value || "";

        var initialContent = hiddenContent && hiddenContent.trim() !== ""
            ? hiddenContent
            : "";

        // === Create Monaco editor ===
        context.editor = monaco.editor.create(document.getElementById("htmlEditor"), {
            value: initialContent,
            language: "xml",
            theme: "vs-dark",
            automaticLayout: true,
            scrollBeyondLastLine: false,
            wordWrap: "on"
            // (native placeholder not available in all Monaco builds)
        });

        window.editor = context.editor; // global reference

        // === Auto-format XML after editor loads ===
        setTimeout(() => {
            if (context.editor.getValue().trim()) {
                context.editor.getAction("editor.action.formatDocument").run();
            }
        }, 500);

        // === Suggestions (completion items) ===
        const suggestions = suggestionArray.map(s => ({
            label: s.label,
            kind: s.kinda,
            insertText: s.insertText,
            insertTextRules: monaco.languages.CompletionItemInsertTextRule.InsertAsSnippet
        }));

        monaco.languages.registerCompletionItemProvider("xml", {
            triggerCharacters: ["@"],
            provideCompletionItems: (model, position) => {
                const wordUntilPos = model.getWordUntilPosition(position);
                const wordRange = {
                    startLineNumber: position.lineNumber,
                    endLineNumber: position.lineNumber,
                    startColumn: wordUntilPos.startColumn,
                    endColumn: wordUntilPos.endColumn
                };
                return { suggestions: suggestions.map(s => ({ ...s, range: wordRange })) };
            }
        });

        // === Snippet fix logic ===
        context.editor.onDidChangeCursorSelection(e => {
            if (e.source === "snippet") {
                const cursor = context.editor.getPosition();
                const content = context.editor.getValue().split("\n");
                let lineContent = content[cursor.lineNumber - 1];

                if (lineContent.includes("@{")) {
                    const idx = lineContent.lastIndexOf("@");
                    lineContent = lineContent.substring(0, idx) + "$" + lineContent.substring(idx + 1);
                } else if (lineContent.includes("@<")) {
                    const idx = lineContent.lastIndexOf("@");
                    lineContent = lineContent.substring(0, idx) + "" + lineContent.substring(idx + 1);
                }

                content[cursor.lineNumber - 1] = lineContent;
                context.editor.setValue(content.join("\n"));
                context.editor.setPosition(cursor);
            }
        });

        // === Sync editor -> hidden input ===
        context.editor.onDidChangeModelContent(() => {
            document.getElementById("workflowFileContent").value = context.editor.getValue();
            $("#errorMessage").hide();
            userActivityDetected(); // for salt refresh
        });

        // === Save shortcut Ctrl/Cmd + S ===
        context.editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyCode.KEY_S, () => {
            typeOfActionWithIsEdit(
                "workflow-definition-form",
                $("#savedAction").find("button"),
                isEdit,
                workFlowdefinition.saveValidation.bind(workFlowdefinition),
                workFlowdefinition.backToPreviousPage
            );
        });

        // === Resize shortcut Ctrl/Cmd + Shift + M ===
        context.editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyMod.Shift | monaco.KeyCode.KEY_M, () => {
            resizeMonacoEditor(context.editor, "htmlContainer", "htmlEditor");
        });
    });
}



document.getElementById("workflowFile").addEventListener("change", function (event) {
    const file = event.target.files[0];
    if (!file) return;

    const allowedExtensions = [".bpmn", ".xml"];
    const fileName = file.name.toLowerCase();
    const isValid = allowedExtensions.some(ext => fileName.endsWith(ext));

    if (!isValid) {
        showMessage("Only .bpmn or .xml files are allowed", "error");
        this.value = ""; // reset invalid file
        return;
    }

    const reader = new FileReader();
    reader.onload = function (e) {
        const fileContent = e.target.result;

        // Update Monaco editor if initialized
        if (window.editor) {
            window.editor.setValue(fileContent);
            window.editor.setPosition({ lineNumber: 1, column: 1 });
            window.editor.focus();
        }

        // Update hidden fields
        document.getElementById("workflowFileContent").value = fileContent;
        document.getElementById("workflowFileName").value = file.name;

        // Hide any previous error messages
        $("#errorMessage").hide();
    };

    reader.readAsText(file);
});

</script>