SELECT definition_id AS definition_id,definition_name AS definition_name,bpmn_xml AS bpmn_xml,version AS version,uploaded_by AS uploaded_by,DATE_FORMAT(uploaded_at, '%Y-%m-%d %H:%i:%s') AS uploaded_at,is_active AS is_active,created_by AS created_by,DATE_FORMAT(created_date, '%Y-%m-%d %H:%i:%s') AS created_date FROM jq_workflow_definition WHERE definition_id =  <#if definitionid??> :definitionid <#else> 'null' </#if>