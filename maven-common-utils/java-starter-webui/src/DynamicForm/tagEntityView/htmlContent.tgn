//To make first row active by default
document.addEventListener('DOMContentLoaded', function () {
    const parentItems = document.querySelectorAll('.parent-item');

    if (parentItems.length > 0) {
        const firstItem = parentItems[0];
        const firstParentId = firstItem.getAttribute('data-id');

        // Show the first child-entities block
        const firstChildEntities = document.getElementById('child-entities-' + firstParentId);
        if (firstChildEntities) {
            firstChildEntities.style.display = 'block';
        }

        // Optional: Add a highlight class to first parent item
        firstItem.classList.add('active');
    }

    // Existing event listener for clicking parent items
    parentItems.forEach(item => {
        item.addEventListener('click', function () {
            const parentId = this.getAttribute('data-id');

            // Hide all child entities initially
            const allChildEntities = document.querySelectorAll('.child-entities');
            allChildEntities.forEach(entity => {
                entity.style.display = 'none';
            });

            // Remove active class from all parent items
            parentItems.forEach(el => el.classList.remove('active'));

            // Add active class to the clicked item
            this.classList.add('active');

            // Show the selected child entities
            const selectedChildEntities = document.getElementById('child-entities-' + parentId);
            if (selectedChildEntities) {
                selectedChildEntities.style.display = 'block';
            }
        });
    });
});

//Done Active By default

//Fetching child Data

document.addEventListener('DOMContentLoaded', function () {
    const parentItems = document.querySelectorAll('.parent-item');
    parentItems.forEach(item => {
        item.addEventListener('click', function () {
            const tagId = this.getAttribute('data-id');
			loadtagEntities(tagId);});
});
});

function loadtagEntities(tagId) {
    if (childDataCache[tagId]) {
        appendChildRows(tagId, childDataCache[tagId]);
    } else {
        const rightColumn = document.querySelector('.right-column');
        rightColumn.innerHTML = '<p>Loading...</p>';

        $.ajax({
            async: false,
            type: "GET",
            url: contextPath + apiPath + "/gted",
            dataType: "json",
            data: {
                tagId: tagId
            },
            success: function (data) {
                childDataCache[tagId] = data;
                appendChildRows(tagId, data);
            },
            error: function (xhr, status, error) {
                console.error("Failed to update module:", error);
                showMessage("Error occurred while updating the module name", "error");
            }
        });
    }
}

//Done fetching child data

function bindChildIconEvents() {
    document.querySelectorAll('.view-icon').forEach(el => {
        el.addEventListener('click', function (e) {
            e.preventDefault();
            const moduleName = this.getAttribute('data-module-name');
            const entityName = this.getAttribute('data-entity-name');
            const entityId   = this.getAttribute('data-entity-id');
            if(moduleName == "REST API"){
                getModuleFormData(moduleName, entityName);
            } else{
                getModuleFormData(moduleName, entityId);
            }
            
          
        });
    });

    document.querySelectorAll('.history-icon').forEach(el => {
        el.addEventListener('click', function (e) {
            e.preventDefault();
            const entityId = this.getAttribute('data-entity-id');
            const moduleName = this.getAttribute('data-module-name');
            const moduleJson = this.getAttribute('data-module-json');
            const moduleId = this.getAttribute('data-module-id');
            const permissionJson = this.getAttribute('data-permission-json');
            const { cmvEntityName, moduleType, saveURL, isNonVersioningModule, nonVersioningFetchURL, versioningFetchURL } = getentityName(moduleId);
            // Set hidden input values
            document.getElementById("entityId").value = entityId;
            document.getElementById("moduleName").value = moduleName;
            document.getElementById("moduleJson").value = moduleJson;
            document.getElementById("moduleId").value = moduleId;
            document.getElementById("isTagView").value = "true";
            $("#isTagView").val("true");
            document.getElementById("cmvEntityName").value = cmvEntityName;
            document.getElementById("moduleType").value = moduleType;
            document.getElementById("isNonVersioningModule").value = isNonVersioningModule;
            document.getElementById("permissionJson").value = permissionJson;
            if(saveURL == ""){
                $("#saveUrl").val("");
            }else{
                $("#saveUrl").val(saveURL);
            }
            if(nonVersioningFetchURL == ""){
                $("#nonVersioningFetchURL").val("");
            }else{
                $("#nonVersioningFetchURL").val(nonVersioningFetchURL);
            }
             if(versioningFetchURL == ""){
                $("#versioningFetchURL").val("");
            }else{
                $("#versioningFetchURL").val(versioningFetchURL);
            }       
                    
            document.getElementById("revisionForm").submit();
        });
    });

    document.querySelectorAll('.unlink-icon').forEach(el => {
        el.addEventListener('click', function (e) {
            e.preventDefault();
            const tagEntityId = this.getAttribute('data-child-id');
            const row = this.closest('tr');
            if (row) {
                let dialog = $('<div id="unlinkConfirmDialog">Are you sure you want to untag this entity?</div>');
                $("body").append(dialog);
                $("#unlinkConfirmDialog").dialog({
                    bgiframe: true,
                    autoOpen: true,
                    modal: true,
                    closeOnEscape: true,
                    draggable: true,
                    resizable: false,
                    title: "Untag",
                    position: { my: "center", at: "center" },
                    buttons: [
                        {
                            text: "Delete",
                            "class": 'btn btn-primary',
                            click: function () {
                                let thisDialog = $(this);
                                $.ajax({
                                    type: 'POST',
                                    url: contextPath + apiPath + "/dted",
									dataType: 'text',
                                    data: { tagEntityId: tagEntityId },
                                    success: function (response) {
                                        row.remove();
                                        showMessage("Entity untagged", "success");
                                    },
                                    error: function (err) {
                                        console.error('Error untagging child:', err);
                                        showMessage("Error occurred while untagging the entity", "error");
                                    },
                                    complete: function () {
                                        thisDialog.dialog("destroy").remove();
                                    }
                                });
                            }
                        },
                        {
                            text: "Cancel",
                            "class": "btn btn-secondary",
                            click: function () {
                                $(this).dialog("destroy").remove();
                            }
                        }
                    ],
                    open: function () {
                        $(".ui-dialog-titlebar button")
                            .removeClass("ui-dialog-titlebar-close")
                            .addClass("ui-button ui-corner-all ui-widget ui-button-icon-only ui-dialog-titlebar-close")
                            .prepend('<span class="ui-button-icon ui-icon ui-icon-closethick"></span>')
                            .append('<span class="ui-button-icon-space"></span>');
                    }
                });
            }
        });
    });
}


function appendChildRows(tagId, data) {
    const rightColumn = document.querySelector('.right-column');
    rightColumn.innerHTML = ""; 
	
    if (data.tagData && data.tagData.length > 0) {
        let tableHtml = `
            <div class="child-entities" id="child-entities-"+tagId style="display: block;">
                <table class="table cstomtble">
                    <thead>
                        <tr>
                            <th class="text-center" width="50%">Module</th>
                            <th class="text-center" width="40%">Entity</th>
                            <th class="text-center" width="10%">Actions</th>
                        </tr>
                    </thead>
                    <tbody>`;

        (data.tagData || []).forEach(child => {
            if (child.module_id === "ded49cbd-ed7c-40ce-b1f8-c2e34ad33473") {
                let moduleObj = JSON.parse(child.moduleJson || "{}");
                if (moduleObj.clientName) {
                    child.child_entity_name = moduleObj.clientName;
                }
            } else if (child.module_id === "fcd0df1f-783f-11eb-94ed-f48e38ab8cd6") {
                let moduleObj = JSON.parse(child.moduleJson || "{}");
                if (moduleObj.scheduler_name) {
                    child.child_entity_name = moduleObj.scheduler_name;
                }
            } else if (child.module_id === "799947cc-b6cb-11eb-8529-0242ac130003") {
                let moduleObj = JSON.parse(child.moduleJson || "{}");
                if (moduleObj.datasourceName) {
                    child.child_entity_name = moduleObj.datasourceName;
                }
            } else if (child.module_id === "5559212c-8c8f-11eb-8dcd-0242ac130003") {
                let moduleObj = JSON.parse(child.moduleJson || "{}");
                if (Array.isArray(moduleObj) && moduleObj.length > 0 && moduleObj[0].resourceKey) {
                    child.child_entity_name = moduleObj[0].resourceKey;
                }
             } else if (child.module_id === "6ac6a54c-8d3f-11eb-8dcd-0242ac130003") {
                let moduleObj = JSON.parse(child.moduleJson || "{}");
                if (moduleObj.entityName) {
                    child.child_entity_name = moduleObj.entityName;
                }
             } else if (child.module_id === "70bd445b-ae33-45dd-98f9-0a0c49463315") {
                let moduleObj = JSON.parse(child.moduleJson || "{}");
                if (moduleObj.libraryName) {
                    child.child_entity_name = moduleObj.libraryName;
                }
             }  else if (child.module_id === "76270518-8c8f-11eb-8dcd-0242ac130003") {
                let moduleObj = JSON.parse(child.moduleJson || "{}");
                if (moduleObj.propertyName) {
                    child.child_entity_name = moduleObj.propertyName;
                }
             }
            tableHtml +=
        "<tr>" +
            "<td>" + child.child_module_name + "</td>" +
            "<td>" + child.child_entity_name + "</td>" +
            "<td>" +
                "<span class='grid_action_icons_ex'>" +
                    "<a href='#' class='view-icon' " +
                        "data-module-name='" + child.child_module_name + "' " +
                        "data-entity-name='" + child.child_entity_name + "' " +
                        " data-entity-id='" + child.child_entity_id + "' " +
                       
                        "title='View'>" +
                        "<i class='fa fa-eye'></i>" +
                    "</a>" +
                    "<a href='#' class='history-icon' " +
                        "data-module-name='" + child.child_module_name + "' " +
                        "data-entity-id='" + child.child_entity_id + "' " +
                        "data-module-json='" + child.moduleJson + "' " +
                        "data-module-id='" + child.module_id + "' " +
                        "data-permission-json='" + child.permissionJson + "' " +
                      
                       
                        "title='History'>" +
                        "<i class='fa fa-history'></i>" +
                    "</a>" + 
                    "<a href='#' class='unlink-icon' " +
                        "data-child-id='" + child.tag_entity_details_id + "' " +
                        "title='Untag'>" +
                        "<i class='fa fa-times-circle'></i>" +
                    "</a>" +
                "</span>" +
            "</td>" +
        "</tr>";
        });

        tableHtml += `</tbody></table></div>`;
        rightColumn.innerHTML = tableHtml;

        // Re-bind events for view/history/unlink icons (after injecting new DOM)
        bindChildIconEvents();
    } else {
        rightColumn.innerHTML = `<div class="child-entities" id="child-entities-"+tagId>
            <p>No tag entity found for this module.</p>
        </div>`;
    }
}

//For # in URL
document.addEventListener('DOMContentLoaded', function () {
    const searchInput = document.getElementById('moduleSearchInput');

    function clearSelection() {
        document.querySelectorAll('.parent-item').forEach(item => {
            item.classList.remove('active');
            item.style.display = '';
        });
        document.querySelectorAll('.child-entities').forEach(panel => {
            panel.style.display = 'none';
        });
    }

    function selectParentModuleByIdOrName(identifier) {
        const searchTerm = identifier.toLowerCase();
        let matched = false;

        document.querySelectorAll('.parent-item').forEach(item => {
            const moduleId = item.getAttribute('data-id')?.toLowerCase();
            const moduleName = item.querySelector('.module-name')?.textContent.trim().toLowerCase();

            if (moduleId === searchTerm || moduleName === searchTerm) {
                matched = true;

                // Hide all others
                document.querySelectorAll('.parent-item').forEach(i => i.style.display = 'none');

                // Show only matched
                item.style.display = '';
                item.classList.add('active');

                if (searchInput) {
                    searchInput.value = item.querySelector('.module-name').textContent.trim();
                }

                const parentId = item.getAttribute('data-id');
                loadtagEntities(parentId); 
            }
        });

        return matched;
    }

    // Input typing
    if (searchInput) {
        searchInput.addEventListener('input', function () {
            const value = this.value.trim().toLowerCase();
            if (value === '') {
                clearSelection();
                return;
            }
            selectParentModuleByIdOrName(value);
        });
    }

    // Hash on load
    const hash = window.location.hash;
    if (hash) {
        const identifier = hash.substring(1);
        selectParentModuleByIdOrName(identifier);
    }
});
//For New Autocomplete........	
let tagNameAutocomplete;
$(function () {	
	 tagNameAutocomplete = $("#tagNameAutocomplete").autocomplete({
            autocompleteId: "getTagName",
            enableClearAll: true,
            render: function(item) {
                var renderStr ='';
                if(item.emptyMsg == undefined || item.emptyMsg === '')
                {
                    renderStr = '<p>'+item.moduleName+'</p>';
                }
                else
                {
                    renderStr = item.emptyMsg;	
                }	    				        
                return renderStr;
            },
            extractText: function(item) {
                return item.moduleName;
            },
            selectedItemRender: function(item){
                return item.moduleName;
            },
            select: function(item) {
                $("#tagNameAutocomplete").blur();
                selectModuleFromSearch(item.moduleId, item.moduleName);			
            }, 	
        });
       
	});
//Done new Autocomplete.
function selectModuleFromSearch(moduleId, moduleName) {
    const parentItems = document.querySelectorAll('.parent-item');
    let matched = false;

    parentItems.forEach(item => {
        const itemId = item.getAttribute('data-id');
        const itemName = item.querySelector('.module-name')?.textContent.trim();

        if (itemId == moduleId || itemName === moduleName) {
            matched = true;
            parentItems.forEach(i => {
                i.style.display = 'none';
                i.classList.remove('active');
            });
            item.style.display = '';
            item.classList.add('active');

            // Load child data
            loadtagEntities(moduleId);

        } else {
            item.classList.remove('active');
        }
    });

    return matched;
}
document.getElementById('tagNameAutocomplete').addEventListener('input', function () {
    const value = this.value.trim();

    if (value === '') {
        document.querySelectorAll('.parent-item').forEach(item => {
            item.style.display = '';
            item.classList.remove('active');
        });
        // Hide all child modules (optional, or you can reset to default behavior)
        document.querySelectorAll('.child-entities').forEach(panel => {
            panel.style.display = 'none';
        });
    }
});
</script>