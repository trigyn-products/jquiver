SELECT notification_id AS entityId,MESSAGE_TEXT AS entityName,jmm.auxiliary_data AS formData
FROM jq_generic_user_notification
LEFT OUTER JOIN jq_master_modules AS jmm ON jmm.module_name = :targetLookupId
WHERE notification_id = :targetTypeId and jmm.module_name = :targetLookupId
UNION ALL
SELECT script_lib_id AS entityId,library_name AS entityName,jmm.auxiliary_data AS formData
FROM jq_script_lib_details
LEFT OUTER JOIN jq_master_modules AS jmm ON jmm.module_name = :targetLookupId
WHERE script_lib_id = :targetTypeId and jmm.module_name = :targetLookupId