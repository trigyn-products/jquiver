var System = Java.type("java.lang.System");

function log2Console(a_strMessage) {
    var isToPrint = true;
    if (isToPrint == false) {
        return;
    }
    System.out.println(a_strMessage);
}

function getHmCssDefaultContent() {
    var templateContent = jq_getDBResult("select template from jq_template_master where template_name = 'hmHeaderDefaultCSS'", null, null).data_list[0];
    return templateContent["template"];
}

getHmCssDefaultContent();