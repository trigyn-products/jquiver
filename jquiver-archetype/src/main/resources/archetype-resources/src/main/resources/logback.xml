<configuration>
	<property name="HOME_LOG" value="JQuiver.log"/>
    <appender name="FILE-ROLLING" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/${HOME_LOG}</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/JQuiver.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- each archived file, size max 2MB -->
            <maxFileSize>5MB</maxFileSize>
            <!-- total size of all archive files, if total size > 200MB, 
				it will delete old archived file -->
            <totalSizeCap>200MB</totalSizeCap>
            <!-- 30 days to keep -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern> %d  - %X{TRNS_ID} -  %p %c [%t] %m%n</pattern>
        </encoder>
    </appender>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <layout class="ch.qos.logback.classic.PatternLayout">
			<pattern>%d{HH:mm:ss.SSS} %green([%thread]) %highlight(%level) %logger{50} - %msg%n</pattern>
    </layout>
    </appender>

    <root level="error">
        <appender-ref ref="STDOUT" />
        <appender-ref ref="FILE-ROLLING"/>
    </root>
</configuration>